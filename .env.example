# Copy to `.env.local` and fill in the values you want.
# Only the NEXT_PUBLIC_* variables are exposed to the browser bundle.

# Public base URL used by the sitemap + OG images. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://whattheindex.com

# Privacy-friendly analytics. Pick at most one.
#
# Plausible: just set your domain. Cloud-hosted by default; for a self-host,
# also set NEXT_PUBLIC_PLAUSIBLE_SRC to your script URL.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=whattheindex.com
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js
#
# Umami: set your website ID. Cloud-hosted by default; for a self-host,
# also set NEXT_PUBLIC_UMAMI_SRC to your script URL.
# NEXT_PUBLIC_UMAMI_ID=00000000-0000-0000-0000-000000000000
# NEXT_PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js
